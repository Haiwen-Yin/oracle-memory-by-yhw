# Oracle AI Database Memory System - Configuration Template
# Copy this file to config.env and fill in your values

# Primary database connection (for write operations)
export PRIMARY_CONN="openclaw@//10.10.10.130:1521/openclaw"

# Standby database connection (for read operations - ADG)
export STANDBY_CONN="openclaw@//10.10.10.131:1521/openclaw_standby"

# Embedding model configuration
export EMBEDDING_MODEL="bge-m3"  # Options: bge-m3, text-embedding-3-small, text-embedding-3-large

# LM Studio API endpoint (for local development)
export LMSTUDIO_ENDPOINT="http://10.10.10.1/v1/embeddings"

# Alternative embedding sources
# export EMBEDDING_SOURCE="ollama"
# export OLLAMA_HOST="localhost"
# export OLLAMA_PORT=11434
# export OLLAMA_MODEL="bge-m3"

# OpenAI (optional, requires API key)
# export OPENAI_API_KEY="your-api-key-here"
# export OPENAI_MODEL="text-embedding-ada-002"

# Health check settings
export HEALTH_CHECK_INTERVAL=3600  # seconds (default: 1 hour)
export HEALTH_CHECK_LOG_FILE="/var/log/memory_health.log"
